{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/commerce/**",
              "components/core/**",
              "ui_kits/boutique/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Cormorant Garamond|Lato|Pinyon Script))/i]",
        "message": "Font not provided by the design system. Available: Cormorant Garamond, Lato, Pinyon Script."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|children|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: variant, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:rare|cabinet)$/]",
        "message": "<Badge> variant must be one of 'rare' | 'cabinet'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|children|href|onClick|disabled|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, children, href, onClick, disabled, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|cabinet-entry|ghost)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'cabinet-entry' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='CategoryTile'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|description|tone|onClick|height|key|ref|className|style|children)$/]",
        "message": "<CategoryTile> doesn't accept that prop. Declared props: name, description, tone, onClick, height."
      },
      {
        "selector": "JSXOpeningElement[name.name='CategoryTile'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:vitrine|cabinet)$/]",
        "message": "<CategoryTile> tone must be one of 'vitrine' | 'cabinet'."
      },
      {
        "selector": "JSXOpeningElement[name.name='EditorialText'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|key|ref|className|style|children)$/]",
        "message": "<EditorialText> doesn't accept that prop. Declared props: children."
      },
      {
        "selector": "JSXOpeningElement[name.name='IrisQuote'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|attribution|key|ref|className|style|children)$/]",
        "message": "<IrisQuote> doesn't accept that prop. Declared props: children, attribution."
      },
      {
        "selector": "JSXOpeningElement[name.name='PriceTag'] > JSXAttribute > JSXIdentifier[name!=/^(?:amount|size|currency|key|ref|className|style|children)$/]",
        "message": "<PriceTag> doesn't accept that prop. Declared props: amount, size, currency."
      },
      {
        "selector": "JSXOpeningElement[name.name='PriceTag'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<PriceTag> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProductCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|price|image|badge|category|onClick|key|ref|className|style|children)$/]",
        "message": "<ProductCard> doesn't accept that prop. Declared props: name, price, image, badge, category, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProductCard'] > JSXAttribute[name.name='badge'] > Literal[value!=/^(?:rare|cabinet)$/]",
        "message": "<ProductCard> badge must be one of 'rare' | 'cabinet'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ReassuranceItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|label|key|ref|className|style|children)$/]",
        "message": "<ReassuranceItem> doesn't accept that prop. Declared props: icon, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionTitle'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|subtitle|onDark|key|ref|className|style|children)$/]",
        "message": "<SectionTitle> doesn't accept that prop. Declared props: children, subtitle, onDark."
      },
      {
        "selector": "JSXOpeningElement[name.name='Separator'] > JSXAttribute > JSXIdentifier[name!=/^(?:motif|onDark|style|key|ref|className|style|children)$/]",
        "message": "<Separator> doesn't accept that prop. Declared props: motif, onDark, style."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
